# Global project environment for local development.
PROJECT_NAME=crowdshield-ai
ENVIRONMENT=development

# Shared infrastructure endpoints.
REDIS_URL=redis://redis:6379/0
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=crowdshield
POSTGRES_USER=crowdshield
POSTGRES_PASSWORD=change_me

# Service metadata.
SERVICE_VERSION=0.1.0
LOG_LEVEL=INFO
FRAME_TARGET_FPS=10
BEHAVIOR_WINDOW_SIZE=30
ALERT_PERSISTENCE_FRAMES=10